<launch>

      <!-- Robot IP -->
      <arg name="robot_ip" default="192.168.125.1"/>

      <!-- ABB bringup -->
      <include file="$(find abb_robot_bringup_examples)/launch/ex3_rws_and_egm_yumi_robot.launch">
            <arg name="robot_ip" value="$(arg robot_ip)" />
            <remap from="/joint_states" to="/yumi/egm/joint_states"/>
      </include>


      <!-- Startup Node -->
      <node pkg="yumi_ros"
            type="yumi_startup_node.py"
            name="yumi_startup"
            output="screen" />

      <node pkg="yumi_ros"
            type="yumi_velocity_guard.py"
            name="yumi_velocity_guard"
            output="screen" />

      <node pkg="yumi_ros"
            type="yumi_session_watchdog.py"
            name="yumi_session_watchdog"
            output="screen" />


      <!-- cartesion velocity controller for both arms -->
      <!-- <node pkg="yumi_ros"
            type="yumi_cartesian_velocity_controller.py"
            name="yumi_dual_arm_cartesian_velocity_controller"
            output="screen">
            <param name="robot_description_param" value="/robot_description" />

            <param name="left_base_link" value="yumi_base_link" />
            <param name="left_tip_link" value="yumi_link_7_l" />

            <param name="right_base_link" value="yumi_base_link" />
            <param name="right_tip_link" value="yumi_link_7_r" />

            <param name="left_input_topic" value="/yumi/robl/cartesian_velocity_command" />
            <param name="right_input_topic" value="/yumi/robr/cartesian_velocity_command" />
            <param name="output_topic" value="/yumi/joint_group_velocity_command" />

            <param name="publish_rate" value="250.0" />
            <param name="command_timeout" value="0.2" />
            <param name="max_joint_velocity" value="0.2" />
            <param name="damping" value="0.03" />
      </node> -->

      <!-- moveit -->
      <include file="$(find yumi_moveit_config)/launch/move_group.launch">
            <!-- <remap from="/joint_states" to="/yumi/egm/joint_states"/> -->
            <remap to="/joint_states" from="/yumi/egm/joint_states"/>
      </include>

      <node pkg="yumi_ros"
            type="yumi_execute_bridge.py"
            name="yumi_execute_bridge"
            output="screen">
      <param name="rate" value="250.0" />
      <param name="kp" value="2.0" />
      <param name="max_vel" value="0.25" />
      <param name="goal_tolerance" value="0.01" />
      <param name="goal_settle_time" value="0.3" />
      </node>

      <!-- joint state republisher to convert from /yumi/egm/joint_states to /joint_states for moveit and other nodes that expect the standard topic name -->
      <node pkg="yumi_ros"
            type="yumi_joint_state_republisher.py"
            name="yumi_joint_state_republisher"
            output="screen">
            <remap from="/input_joint_states" to="/yumi/egm/joint_states" />
            <remap from="/output_joint_states" to="/joint_states" />
      </node>

      <!-- robot description -->

      <arg name="arms_interface" default="VelocityJointInterface" />
      <arg name="grippers_interface" default="PositionJointInterface" />
      <arg name="yumi_parent" default="world" />

      <param name="robot_description"
            command="$(find xacro)/xacro $(find yumi_description)/urdf/yumi.urdf.xacro arms_interface:=$(arg arms_interface) grippers_interface:=$(arg grippers_interface) yumi_parent:=$(arg yumi_parent)" />

      <node pkg="robot_state_publisher"
            type="robot_state_publisher"
            name="robot_state_publisher"
            output="screen">
            <remap from="joint_states" to="/yumi/egm/joint_states" />
      </node>



</launch>